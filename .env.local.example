# =============================================
# VendorRank AI — Environment Variables
# =============================================

# DATABASE (PostgreSQL required)
DATABASE_URL="postgresql://username:password@localhost:5432/vendorrank"

# =============================================
# HEDERA CONFIGURATION
# =============================================
# Create a testnet account at https://portal.hedera.com
HEDERA_ACCOUNT_ID="0.0.XXXXXXX"
HEDERA_PRIVATE_KEY="your-der-encoded-private-key"    # DER-encoded private key
HEDERA_NETWORK="testnet"

# After running /api/hedera/init-topic, paste the returned topicId here
HEDERA_TOPIC_ID=""

# Optional: If you pre-created an HTS badge token, paste its ID here
# If not set, a new token is created on first badge mint
HEDERA_BADGE_TOKEN_ID=""

# =============================================
# AI PROVIDER
# =============================================
# Provide at least one key. App auto-detects which provider to use.
# Set AI_PROVIDER to force a specific provider (openai or anthropic).
OPENAI_API_KEY="sk-proj-..."
# ANTHROPIC_API_KEY="sk-ant-..."
AI_PROVIDER="openai"
AI_MODEL="gpt-4o-mini"

# =============================================
# NEXT.JS / APP
# =============================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_MIRROR_NODE_URL="https://testnet.mirrornode.hedera.com"
